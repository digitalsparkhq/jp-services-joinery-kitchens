---
// src/pages/contact.astro
import Layout from '../layouts/Layout.astro';
---

<Layout 
  title="Contact Us"
  description="Contact JPservices for premium kitchen installations, LVT flooring, and bespoke joinery in Hull and surrounding areas. Get a free, no-obligation quote today."
>
  <main class="bg-stone-50">
    
    <section class="relative pt-40 pb-48 lg:pt-48 lg:pb-64 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1600566753190-17f0baa2a6c3?q=80&w=2070&auto=format&fit=crop');">
      
      <div class="absolute inset-0 bg-brand-dark/80 mix-blend-multiply"></div>
      <div class="absolute inset-0 bg-gradient-to-b from-brand-dark/90 via-transparent to-stone-50/90"></div>

      <div class="relative z-10 max-w-4xl mx-auto px-6 text-center">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-accent/20 border border-brand-accent/30 text-brand-accent-light font-bold text-sm tracking-wider mb-6 backdrop-blur-sm">
          LET'S CONNECT
        </div>
        <h1 class="text-5xl md:text-6xl lg:text-7xl font-black text-white mb-6 tracking-tight uppercase drop-shadow-lg shadow-black">
          Start Your <span class="text-brand-accent">Project.</span>
        </h1>
        <p class="text-xl text-white/90 max-w-2xl mx-auto font-medium leading-relaxed drop-shadow-md shadow-black">
          Whether you need a complete kitchen overhaul or pristine Herringbone flooring, get in touch with our Hull experts today.
        </p>
      </div>
    </section>

    <section class="relative z-20 px-6 lg:px-12 -mt-32 lg:-mt-48 pb-24">
      <div class="max-w-[1400px] mx-auto">
        
        <div class="flex flex-col lg:flex-row bg-white rounded-2xl shadow-[0_30px_60px_rgba(0,0,0,0.15)] overflow-hidden border border-stone-200">
          
          <div class="lg:w-1/3 bg-brand-dark text-white p-10 lg:p-14 flex flex-col justify-between relative overflow-hidden">
            <div class="absolute bottom-0 right-0 w-64 h-64 bg-brand-accent/10 rounded-full blur-[80px] pointer-events-none translate-x-1/3 translate-y-1/3"></div>

            <div>
              <h3 class="text-3xl font-extrabold mb-4 tracking-tight">Get in touch</h3>
              <p class="text-white/60 mb-12 leading-relaxed">
                We'd love to hear from you. Our friendly team is always here to chat about your next home transformation.
              </p>

              <div class="space-y-8">
                <div class="flex items-start gap-4 group">
                  <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center shrink-0 group-hover:border-brand-accent/50 transition-colors">
                    <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
                  </div>
                  <div>
                    <p class="text-sm text-white/50 uppercase tracking-wider font-bold mb-1">Call Us</p>
                    <a href="tel:+447787628086" class="text-xl font-bold hover:text-brand-accent transition-colors">07787 628086</a>
                  </div>
                </div>

                <div class="flex items-start gap-4 group">
                  <div class="w-12 h-12 rounded-full bg-white/5 border border-white/10 flex items-center justify-center shrink-0 group-hover:border-brand-accent/50 transition-colors">
                    <svg class="w-5 h-5 text-brand-accent" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
                  </div>
                  <div>
                    <p class="text-sm text-white/50 uppercase tracking-wider font-bold mb-1">Service Area</p>
                    <p class="text-lg font-bold">Kingston upon Hull</p>
                    <p class="text-white/60">HU12 9BF & Surrounding Areas</p>
                  </div>
                </div>
              </div>
            </div>

            <div class="mt-16 pt-8 border-t border-white/10">
              <p class="text-sm font-bold text-white/50 uppercase tracking-wider mb-4">See Our Work</p>
              <a href="https://www.facebook.com/hulljoinery" target="_blank" class="inline-flex items-center gap-3 text-white hover:text-brand-accent font-bold transition-colors">
                <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
                Follow us on Facebook
              </a>
            </div>
          </div>

          <div class="lg:w-2/3 p-10 lg:p-14 bg-white relative">
            <h3 class="text-2xl font-extrabold text-brand-dark mb-2">Request a Free Quote</h3>
            <p class="text-stone-500 mb-8 text-sm border-b border-stone-100 pb-6">Fill in the details below and we'll get straight back to you via WhatsApp.</p>
            
            <form id="contact-page-whatsapp-form" class="space-y-6">
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-bold text-stone-700 mb-2">Your Name *</label>
                  <input id="pg-name" type="text" required class="w-full bg-stone-50 border border-stone-200 rounded-lg px-4 py-3.5 text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent transition-all" placeholder="John Doe">
                </div>
                <div>
                  <label class="block text-sm font-bold text-stone-700 mb-2">Phone Number *</label>
                  <input id="pg-phone" type="tel" required class="w-full bg-stone-50 border border-stone-200 rounded-lg px-4 py-3.5 text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent transition-all" placeholder="07787 628086">
                </div>
              </div>
              
              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-bold text-stone-700 mb-2">Email Address</label>
                  <input id="pg-email" type="email" class="w-full bg-stone-50 border border-stone-200 rounded-lg px-4 py-3.5 text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent transition-all" placeholder="Optional">
                </div>
                <div>
                  <label class="block text-sm font-bold text-stone-700 mb-2">Postcode *</label>
                  <input id="pg-postcode" type="text" required class="w-full bg-stone-50 border border-stone-200 rounded-lg px-4 py-3.5 text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent transition-all" placeholder="e.g. HU12 9BF">
                </div>
              </div>

              <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <div>
                  <label class="block text-sm font-bold text-stone-700 mb-2">Service Required *</label>
                  <select id="pg-service" required class="w-full bg-stone-50 border border-stone-200 rounded-lg px-4 py-3.5 text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent transition-all appearance-none cursor-pointer">
                    <option value="" disabled selected>Select a Service...</option>
                    <option value="Kitchen Installation">Kitchen Installation</option>
                    <option value="Luxury Vinyl Tile (LVT) Fitting">Luxury Vinyl Tile (LVT) Fitting</option>
                    <option value="Herringbone / Parquet Flooring">Herringbone / Parquet Flooring</option>
                    <option value="Subfloor Preparation">Subfloor Preparation</option>
                    <option value="General Joinery">General Joinery</option>
                    <option value="Other / Multiple Services">Other / Multiple Services</option>
                  </select>
                </div>
                <div>
                  <label class="block text-sm font-bold text-stone-700 mb-2">Timescale *</label>
                  <select id="pg-timescale" required class="w-full bg-stone-50 border border-stone-200 rounded-lg px-4 py-3.5 text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent transition-all appearance-none cursor-pointer">
                    <option value="" disabled selected>When do you need this?</option>
                    <option value="As soon as possible">As soon as possible</option>
                    <option value="Within a month">Within a month</option>
                    <option value="In the next few months">In the next few months</option>
                    <option value="Just getting a quote/Flexible">Just getting a quote / Flexible</option>
                  </select>
                </div>
              </div>

              <div>
                <label class="block text-sm font-bold text-stone-700 mb-2">Project Details</label>
                <textarea id="pg-details" rows="4" class="w-full bg-stone-50 border border-stone-200 rounded-lg px-4 py-3.5 text-stone-900 focus:outline-none focus:ring-2 focus:ring-brand-accent focus:border-transparent transition-all resize-y" placeholder="Tell us a bit more about what you are looking for..."></textarea>
              </div>

              <div class="pt-4">
                <button type="submit" class="w-full bg-[#25D366] hover:bg-[#1da851] text-white font-bold py-4 px-8 rounded-lg shadow-[0_10px_20px_rgba(37,211,102,0.2)] transition-all duration-300 transform hover:-translate-y-1 flex items-center justify-center gap-3 cursor-pointer uppercase tracking-wider text-sm border-0">
                  <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                  Send Message via WhatsApp
                </button>
              </div>
            </form>
          </div>
          
        </div>
      </div>
    </section>
    
  </main>
</Layout>

<script>
  // Dedicated WhatsApp Form Submission Logic for the Contact Page
  const pageForm = document.getElementById('contact-page-whatsapp-form') as HTMLFormElement;

  if (pageForm) {
    pageForm.addEventListener('submit', (e) => {
      e.preventDefault(); 

      // Grab values from inputs safely
      const name = (document.getElementById('pg-name') as HTMLInputElement)?.value || '';
      const phone = (document.getElementById('pg-phone') as HTMLInputElement)?.value || '';
      const email = (document.getElementById('pg-email') as HTMLInputElement)?.value || 'Not provided';
      const postcode = (document.getElementById('pg-postcode') as HTMLInputElement)?.value || '';
      const service = (document.getElementById('pg-service') as HTMLSelectElement)?.value || '';
      const timescale = (document.getElementById('pg-timescale') as HTMLSelectElement)?.value || '';
      const details = (document.getElementById('pg-details') as HTMLTextAreaElement)?.value || 'None';

      // Format the WhatsApp message specifically for the Contact Page
      const message = `*New Lead via Contact Page* 🔨\n\n*Name:* ${name}\n*Phone:* ${phone}\n*Email:* ${email}\n*Postcode:* ${postcode}\n*Service Needed:* ${service}\n*Timescale:* ${timescale}\n*Details:* ${details}`;

      // Encode for URL and open WhatsApp (targeting the JPservices number)
      const whatsappUrl = `https://wa.me/447787628086?text=${encodeURIComponent(message)}`;
      window.open(whatsappUrl, '_blank');

      // Reset the form so it's ready if they come back
      pageForm.reset();
    });
  }
</script>