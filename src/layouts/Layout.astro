---
import '../styles/global.css';
import Header from '../components/Header.astro';
import QuoteForm from '../components/QuoteForm.astro';
import Footer from '../components/Footer.astro';


interface Props {
	title: string;
	description?: string; // <-- Add this line right here!
}

const { title, description = "Premium joinery, kitchen installations, and LVT flooring fitting in Hull and surrounding areas." } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<meta name="description" content="JPservices - Premium joinery, kitchen installations, and LVT flooring fitting in Hull and surrounding areas. Quality craftsmanship from the floor up." />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
		
		<title>{title} | JPservices</title>
	</head>
	
	<body class="bg-stone-50 text-brand-charcoal antialiased font-sans flex flex-col min-h-screen relative">
		
		<Header />

		<main class="flex-grow">
			<slot />
		</main>

		<QuoteForm />
        <Footer />
		
	</body>
</html>