---
// src/components/Services.astro

const services = [
  {
    title: "Kitchen Installations",
    description: "Flawless kitchen fitting to the highest standard. We handle everything to deliver your dream kitchen at a competitive price.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"></path></svg>`
  },
  {
    title: "Luxury LVT Flooring",
    description: "Premium LVT fitting including elegant Herringbone and Parquet patterns. Durable, stunning, and perfect for any room.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z"></path></svg>`
  },
  {
    title: "Subfloor Preparation",
    description: "The foundation of a perfect floor. We provide expert leveling, screeding, and prep work to ensure a flawless final finish.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path></svg>`
  },
  {
    title: "All Aspects of Joinery",
    description: "From custom woodwork to structural joinery. Precision craftsmanship tailored to your home's unique requirements.",
    icon: `<svg class="w-10 h-10" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M14.121 14.121L19 19m-7-7l7-7m-7 7l-2.879 2.879M12 12L9.121 9.121m0 5.758a3 3 0 10-4.243-4.243 3 3 0 004.243 4.243z"></path></svg>`
  }
];
---

<section id="services" class="py-24 bg-[#0a0a0a] relative border-t border-white/5">
  
  <div class="absolute top-0 left-1/2 -translate-x-1/2 w-48 h-1 bg-brand-accent rounded-b-full opacity-70 shadow-[0_0_15px_rgba(197,160,89,0.5)]"></div>

  <div class="max-w-[1600px] mx-auto px-8 lg:px-12">
    
    <div class="text-center mb-20 max-w-3xl mx-auto">
      <span class="inline-block py-1 px-3 border border-brand-accent/30 text-brand-accent font-bold text-sm mb-4 rounded uppercase tracking-widest bg-brand-accent/5">
        Our Expertise
      </span>
      <h2 class="text-4xl md:text-5xl font-black text-white mb-6 uppercase tracking-tight">
        Quality Craftsmanship
      </h2>
      <p class="text-lg text-white/70 leading-relaxed">
        Whether you are completely remodeling your kitchen or upgrading your living room with stunning Herringbone LVT, we provide a premium, end-to-end service.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-8">
      {services.map((service) => (
        <div class="group relative bg-[#121212] border border-white/5 p-8 rounded-xl hover:border-brand-accent/50 transition-all duration-500 hover:-translate-y-2 hover:shadow-2xl hover:shadow-brand-accent/10 flex flex-col items-center text-center overflow-hidden">
          
          <div class="absolute inset-0 bg-gradient-to-b from-brand-accent/5 to-transparent opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none"></div>
          
          <div class="w-20 h-20 bg-brand-dark border border-white/10 rounded-full flex items-center justify-center text-brand-accent mb-6 group-hover:scale-110 group-hover:bg-brand-accent group-hover:text-brand-dark transition-all duration-500 relative z-10 shadow-lg">
            <Fragment set:html={service.icon} />
          </div>
          
          <h3 class="text-2xl font-bold text-white mb-4 relative z-10">{service.title}</h3>
          <p class="text-white/60 leading-relaxed relative z-10 group-hover:text-white/80 transition-colors duration-300">
            {service.description}
          </p>
          
        </div>
      ))}
    </div>

    <div class="mt-20 text-center">
      <p class="text-white/80 text-lg mb-6">Ready to give your space a fresh look?</p>
      <button class="quote-trigger inline-flex items-center justify-center bg-transparent border-2 border-brand-accent text-brand-accent hover:bg-brand-accent hover:text-brand-dark font-bold py-3 px-8 rounded transition-all duration-300 uppercase tracking-wide cursor-pointer">
        Get a Free No-Obligation Quote
        <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"></path></svg>
      </button>
    </div>

  </div>
</section>