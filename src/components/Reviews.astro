---
// src/components/Reviews.astro

const reviews = [
  {
    name: "Christina Diamond-Lisney",
    text: "Kenny recently fitted my new kitchen. I am very pleased with his work. He sorted any problems which cropped up efficiently. The end result is great and he did all the work on time. Communication was excellent."
  },
  {
    name: "Bridget Cammish",
    text: "They have just fitted a new kitchen for me. Cannot recommend them highly enough. Excellent job done. Little hiccups along the way as expected because it is an old property and an old kitchen but problems solved very professionally. Would definitely recommend them to everyone."
  },
  {
    name: "Roland Wheeler-Osman",
    text: "I have no hesitation in recommending JP Services. Kenny and Dave are fanatical about getting every small detail perfect, and the quality of their work is outstanding. My new kitchen looks fantastic. Thank you for a brilliant job."
  }
];
---

<section id="reviews" class="py-24 bg-stone-50 relative overflow-hidden border-t border-stone-200">
  
  <div class="absolute inset-0 opacity-[0.02]" style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 24px 24px;"></div>

  <div class="max-w-[1600px] mx-auto px-6 lg:px-12 relative z-10">
    
    <div class="text-center mb-16 max-w-3xl mx-auto">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full bg-brand-accent/10 border border-brand-accent/20 text-brand-dark font-bold text-sm tracking-wider mb-6">
        CLIENT TESTIMONIALS
      </div>
      <h2 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight text-brand-dark uppercase tracking-tight">
        Trusted by local <span class="text-brand-accent">homeowners.</span>
      </h2>
      <p class="text-lg text-stone-600 leading-relaxed">
        We pride ourselves on communication, problem-solving, and fanatical attention to detail. Don't just take our word for it—read what our clients have to say.
      </p>
    </div>

    <div class="flex items-center justify-center gap-2 mb-6 text-brand-accent/80 text-sm font-bold tracking-wide md:hidden animate-pulse">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M7 16l-4-4m0 0l4-4m-4 4h18"></path></svg>
      SWIPE TO READ
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4-4m4-4H3"></path></svg>
    </div>

    <div class="flex overflow-x-auto snap-x snap-mandatory hide-scrollbar md:grid md:grid-cols-3 gap-6 md:gap-8 pb-8 md:pb-0 px-2 md:px-0">
      
      {reviews.map((review) => (
        <div class="snap-center shrink-0 w-[90vw] sm:w-[400px] md:w-auto relative group">
          
          <div class="h-full bg-white p-8 md:p-10 rounded-2xl border border-stone-200 hover:border-brand-accent/40 transition-all duration-500 shadow-[0_8px_30px_rgb(0,0,0,0.04)] hover:shadow-[0_8px_30px_rgba(197,160,89,0.1)] relative overflow-hidden flex flex-col">
            
            <svg class="absolute -top-4 -right-4 w-32 h-32 text-stone-100 transform rotate-12 group-hover:text-brand-accent/5 transition-colors duration-500 pointer-events-none" fill="currentColor" viewBox="0 0 24 24">
              <path d="M14.017 21v-7.391c0-5.704 3.731-9.57 8.983-10.609l.995 2.151c-2.432.917-3.995 3.638-3.995 5.849h4v10h-9.983zm-14.017 0v-7.391c0-5.704 3.748-9.57 9-10.609l.996 2.151c-2.433.917-3.996 3.638-3.996 5.849h3.983v10h-9.983z"/>
            </svg>

            <div class="flex gap-1 mb-6 relative z-10">
              {[1, 2, 3, 4, 5].map(() => (
                <svg class="w-5 h-5 text-brand-accent drop-shadow-sm" fill="currentColor" viewBox="0 0 20 20">
                  <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
                </svg>
              ))}
            </div>

            <p class="text-stone-600 text-lg leading-relaxed italic mb-8 relative z-10 flex-grow">
              "{review.text}"
            </p>

            <div class="mt-auto relative z-10 flex items-center gap-4 border-t border-stone-100 pt-6">
              <div class="w-12 h-12 rounded-full bg-brand-accent/10 flex items-center justify-center text-brand-accent font-bold text-xl">
                {review.name.charAt(0)}
              </div>
              <div>
                <p class="text-brand-dark font-bold tracking-wide">{review.name}</p>
                <div class="flex items-center gap-1 mt-0.5">
                  <svg class="w-4 h-4 text-green-600" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"></path></svg>
                  <p class="text-stone-500 text-sm font-medium">Verified Customer</p>
                </div>
              </div>
            </div>

          </div>
        </div>
      ))}

    </div>
  </div>
</section>

<style>
  /* Custom utility class to hide scrollbars while allowing swipe */
  .hide-scrollbar {
    -ms-overflow-style: none;  /* IE and Edge */
    scrollbar-width: none;  /* Firefox */
  }
  .hide-scrollbar::-webkit-scrollbar {
    display: none; /* Chrome, Safari and Opera */
  }
</style>