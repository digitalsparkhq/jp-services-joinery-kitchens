---
// src/components/Footer.astro
---

<footer class="bg-brand-dark text-white/70 relative overflow-hidden">
  
  <div class="absolute top-0 right-0 w-96 h-96 bg-brand-accent/5 rounded-full blur-[120px] pointer-events-none -translate-y-1/2 translate-x-1/3"></div>

  <div class="border-b border-white/10">
    <div class="max-w-[1600px] mx-auto px-8 lg:px-12 py-16 lg:py-20 flex flex-col md:flex-row justify-between items-center gap-8">
      
      <div class="text-center md:text-left">
        <h3 class="text-3xl md:text-4xl font-extrabold text-white mb-4 tracking-tight">
          Ready to transform your home?
        </h3>
        <p class="text-lg text-white/60 max-w-xl">
          From the first measurement to the final sweep, we guarantee precision and care. Let's discuss your next project.
        </p>
      </div>

      <div class="shrink-0">
        <button class="quote-trigger cursor-pointer bg-brand-accent hover:bg-brand-accent-light text-brand-dark font-bold py-4 px-10 rounded shadow-[0_0_30px_rgba(197,160,89,0.2)] transition-all duration-300 transform hover:-translate-y-1 text-lg uppercase tracking-wide border-0 flex items-center gap-3">
          Get Your Free Quote
          <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M14 5l7 7m0 0l-7 7m7-7H3"></path></svg>
        </button>
      </div>
      
    </div>
  </div>

  <div class="max-w-[1600px] mx-auto px-8 lg:px-12 py-16 lg:py-20">
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-12 gap-12 lg:gap-8 text-center md:text-left">
      
      <div class="lg:col-span-5 lg:pr-12 flex flex-col items-center md:items-start">
        <a href="/" class="inline-block mb-6">
           <h2 class="text-2xl font-black text-white tracking-widest uppercase">
             JP<span class="text-brand-accent font-light">SERVICES</span>
           </h2>
        </a>
        <p class="text-white/60 leading-relaxed mb-8 max-w-md">
          Premium joinery, bespoke kitchens, and flawless LVT flooring installations across Kingston upon Hull and surrounding areas.
        </p>
        <div class="flex gap-4">
          <a href="https://www.facebook.com/hulljoinery" target="_blank" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/70 hover:bg-brand-accent hover:border-brand-accent hover:text-brand-dark transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987h-2.54V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/></svg>
          </a>
          <a href="https://wa.me/447787628086" target="_blank" class="w-10 h-10 rounded-full border border-white/20 flex items-center justify-center text-white/70 hover:bg-brand-accent hover:border-brand-accent hover:text-brand-dark transition-all duration-300">
            <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
          </a>
        </div>
      </div>

      <div class="lg:col-span-3 lg:justify-self-center">
        <h4 class="text-white font-bold tracking-widest uppercase mb-6 text-sm">Navigation</h4>
        <ul class="space-y-3">
          <li><a href="/" class="hover:text-brand-accent transition-colors">Home</a></li>
          <li><a href="/#about" class="hover:text-brand-accent transition-colors">About Us</a></li>
          <li><a href="/#services" class="hover:text-brand-accent transition-colors">Our Services</a></li>
          <li><a href="/#gallery" class="hover:text-brand-accent transition-colors">Project Gallery</a></li>
          <li><a href="/contact" class="hover:text-brand-accent transition-colors">Contact</a></li>
        </ul>
      </div>

      <div class="lg:col-span-4 lg:justify-self-end">
        <h4 class="text-white font-bold tracking-widest uppercase mb-6 text-sm">Get in Touch</h4>
        <ul class="space-y-4 flex flex-col items-center md:items-start">
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"></path></svg>
            <a href="tel:+447787628086" class="hover:text-brand-accent transition-colors font-medium">07787 628086</a>
          </li>
          <li class="flex items-start gap-3">
            <svg class="w-5 h-5 text-brand-accent shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"></path><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"></path></svg>
            <div class="text-left md:text-left">
              <p class="font-medium text-white/90">Kingston upon Hull</p>
              <p class="text-sm text-white/50 mt-1">HU12 9BF</p>
            </div>
          </li>
        </ul>
      </div>

    </div>
  </div>

  <div class="border-t border-white/5 bg-[#050505]">
    <div class="max-w-[1600px] mx-auto px-8 lg:px-12 py-6 flex flex-col md:flex-row justify-between items-center text-sm text-white/40 gap-4">
      <p class="text-center md:text-left">
        © {new Date().getFullYear()} JPservices Joinery, Kitchens & Flooring. All rights reserved.
      </p>
      <p class="text-center">
        Designed & Built by 
        <a href="https://digitalsparkhq.com/" target="_blank" class="text-brand-accent hover:text-brand-accent-light font-bold transition-colors tracking-wide ml-1">
          Digital Spark HQ
        </a>
      </p>
    </div>
  </div>

</footer>