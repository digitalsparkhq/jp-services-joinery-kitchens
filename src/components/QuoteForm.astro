---
// src/components/QuoteForm.astro
---

<div id="quote-modal-overlay" class="fixed inset-0 z-[100] hidden bg-black/80 backdrop-blur-sm flex items-center justify-center p-4 opacity-0 transition-opacity duration-300">
  <div class="bg-brand-dark rounded-2xl w-full max-w-2xl p-8 md:p-10 relative border border-brand-accent/20 shadow-[0_0_40px_rgba(197,160,89,0.1)] transform scale-95 transition-transform duration-300 max-h-[90vh] overflow-y-auto" id="quote-modal-content">    
    
    <button id="close-quote-modal" class="absolute top-6 right-6 cursor-pointer text-white/50 hover:text-brand-accent transition-colors">
      <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" /></svg>
    </button>
    
    <h3 class="text-3xl font-extrabold text-white mb-2">Request a Free Quote</h3>
    <p class="text-white/60 mb-8 text-sm">Fill out the details below and we will get back to you shortly via WhatsApp.</p>
    
    <form id="whatsapp-quote-form" class="space-y-4">
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-white/60 mb-1">Your Name *</label>
          <input id="q-name" type="text" required class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all" placeholder="John Doe">
        </div>
        <div>
          <label class="block text-xs font-medium text-white/60 mb-1">Phone Number *</label>
          <input id="q-phone" type="tel" required class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all" placeholder="07787 628086">
        </div>
      </div>
      
      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-white/60 mb-1">Email Address</label>
          <input id="q-email" type="email" class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all" placeholder="Optional">
        </div>
        <div>
          <label class="block text-xs font-medium text-white/60 mb-1">Postcode *</label>
          <input id="q-postcode" type="text" required class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all" placeholder="e.g. HU12 9BF">
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div>
          <label class="block text-xs font-medium text-white/60 mb-1">Service Required *</label>
          <select id="q-service" required class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-2.5 text-white/90 focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all appearance-none cursor-pointer">
            <option value="" disabled selected>Select a Service...</option>
            <option value="Kitchen Installation">Kitchen Installation</option>
            <option value="Luxury Vinyl Tile (LVT) Fitting">Luxury Vinyl Tile (LVT) Fitting</option>
            <option value="Herringbone / Parquet Flooring">Herringbone / Parquet Flooring</option>
            <option value="Subfloor Preparation">Subfloor Preparation</option>
            <option value="General Joinery">General Joinery</option>
            <option value="Other / Multiple Services">Other / Multiple Services</option>
          </select>
        </div>
        <div>
          <label class="block text-xs font-medium text-white/60 mb-1">Timescale *</label>
          <select id="q-timescale" required class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-2.5 text-white/90 focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all appearance-none cursor-pointer">
            <option value="" disabled selected>When do you need this?</option>
            <option value="As soon as possible">As soon as possible</option>
            <option value="Within a month">Within a month</option>
            <option value="In the next few months">In the next few months</option>
            <option value="Just getting a quote/Flexible">Just getting a quote / Flexible</option>
          </select>
        </div>
      </div>

      <div>
        <label class="block text-xs font-medium text-white/60 mb-1">Project Details</label>
        <textarea id="q-details" rows="3" class="w-full bg-black/50 border border-white/10 rounded-lg px-4 py-2.5 text-white focus:outline-none focus:border-brand-accent focus:ring-1 focus:ring-brand-accent transition-all" placeholder="Tell us a bit more about what you are looking for..."></textarea>
      </div>
      
      <button type="submit" class="cursor-pointer w-full bg-[#25D366] hover:bg-[#1da851] text-white font-bold py-3 px-8 rounded-lg shadow-lg transition-all duration-300 transform hover:-translate-y-1 mt-2 flex justify-center items-center gap-2">
        <svg class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51a12.8 12.8 0 00-.57-.01c-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Send via WhatsApp
      </button>
    </form>
  </div>
</div>

<script>
  // Modal toggle logic
  const quoteTriggers = document.querySelectorAll('.quote-trigger');
  const quoteModalOverlay = document.getElementById('quote-modal-overlay');
  const quoteModalContent = document.getElementById('quote-modal-content');
  const closeQuoteModal = document.getElementById('close-quote-modal');
  const mobileMenuOverlay = document.getElementById('mobile-menu-overlay');

  const openModal = () => {
    if(quoteModalOverlay && quoteModalContent) {
      if(mobileMenuOverlay && !mobileMenuOverlay.classList.contains('hidden')) {
         mobileMenuOverlay.classList.add('opacity-0');
         setTimeout(() => mobileMenuOverlay.classList.add('hidden'), 300);
         document.body.style.overflow = 'auto'; 
      }
      
      quoteModalOverlay.classList.remove('hidden');
      setTimeout(() => {
        quoteModalOverlay.classList.remove('opacity-0');
        quoteModalContent.classList.remove('scale-95');
        quoteModalContent.classList.add('scale-100');
      }, 10);
      document.body.style.overflow = 'hidden';
    }
  };

  const closeModal = () => {
    if(quoteModalOverlay && quoteModalContent) {
      quoteModalOverlay.classList.add('opacity-0');
      quoteModalContent.classList.remove('scale-100');
      quoteModalContent.classList.add('scale-95');
      setTimeout(() => quoteModalOverlay.classList.add('hidden'), 300);
      document.body.style.overflow = 'auto';
    }
  };

  quoteTriggers.forEach(btn => btn.addEventListener('click', openModal));
  if(closeQuoteModal) closeQuoteModal.addEventListener('click', closeModal);
  
  if(quoteModalOverlay) {
    quoteModalOverlay.addEventListener('click', (e) => {
      if(e.target === quoteModalOverlay) closeModal();
    });
  }

  // --- WHATSAPP FORM SUBMISSION LOGIC ---
  const whatsappForm = document.getElementById('whatsapp-quote-form') as HTMLFormElement;

  if (whatsappForm) {
    whatsappForm.addEventListener('submit', (e) => {
      e.preventDefault(); // Stop the page from refreshing

      // Grab values from inputs
      const name = (document.getElementById('q-name') as HTMLInputElement)?.value || '';
      const phone = (document.getElementById('q-phone') as HTMLInputElement)?.value || '';
      const email = (document.getElementById('q-email') as HTMLInputElement)?.value || 'Not provided';
      const postcode = (document.getElementById('q-postcode') as HTMLInputElement)?.value || '';
      const service = (document.getElementById('q-service') as HTMLSelectElement)?.value || '';
      const timescale = (document.getElementById('q-timescale') as HTMLSelectElement)?.value || '';
      const details = (document.getElementById('q-details') as HTMLTextAreaElement)?.value || 'None';

      // Format the WhatsApp message (added a hammer emoji for joinery!)
      const message = `*New Quote Request from Website* 🔨\n\n*Name:* ${name}\n*Phone:* ${phone}\n*Email:* ${email}\n*Postcode:* ${postcode}\n*Service Needed:* ${service}\n*Timescale:* ${timescale}\n*Details:* ${details}`;

      // UPDATED TO JP SERVICES WHATSAPP NUMBER
      const whatsappUrl = `https://wa.me/447787628086?text=${encodeURIComponent(message)}`;
      window.open(whatsappUrl, '_blank');

      // Close modal and reset form
      closeModal();
      whatsappForm.reset();
    });
  }
</script>