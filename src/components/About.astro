---
// src/components/About.astro
---

<section id="about" class="py-24 bg-brand-dark relative overflow-hidden border-t border-white/5">
  
  <div class="absolute top-1/2 left-0 -translate-y-1/2 w-96 h-96 bg-brand-accent/5 rounded-full blur-[120px] pointer-events-none"></div>

  <div class="max-w-[1600px] mx-auto px-8 lg:px-12 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <div class="relative group">
        <div class="absolute -inset-4 border-2 border-brand-accent/20 rounded-2xl transform translate-x-4 translate-y-4 -z-10 transition-transform duration-500 group-hover:translate-x-2 group-hover:translate-y-2"></div>
        <div class="absolute -inset-4 bg-brand-accent/5 rounded-2xl transform -translate-x-2 -translate-y-2 -z-10"></div>
        
        <div class="relative rounded-xl overflow-hidden shadow-[0_20px_50px_rgba(0,0,0,0.5)] aspect-[4/5] md:aspect-auto md:h-[600px] w-full">
          <img 
            src="/images/about.jpg" 
            alt="JPservices Joinery and Flooring Craftsmanship" 
            class="w-full h-full object-cover transform transition-transform duration-700 group-hover:scale-105"
            loading="lazy"
          />
          <div class="absolute inset-0 bg-gradient-to-t from-brand-dark/80 via-transparent to-transparent opacity-60"></div>
        </div>
      </div>

      <div class="max-w-2xl">
        <div class="inline-block px-4 py-1.5 rounded-full bg-brand-accent/10 border border-brand-accent/20 text-brand-accent font-bold text-sm tracking-wider mb-6">
          ABOUT JPSERVICES
        </div>
        
        <h2 class="text-4xl md:text-5xl font-extrabold mb-8 leading-tight text-white uppercase tracking-tight">
          Quality craftsmanship <br/><span class="text-brand-accent-light">from the floor up.</span>
        </h2>
        
        <p class="text-white/70 text-lg mb-6 leading-relaxed">
          Based in Hull, JPservices is a team of dedicated professionals specializing in premium kitchen installations, luxury LVT flooring, and bespoke joinery. 
        </p>
        <p class="text-white/70 text-lg mb-12 leading-relaxed">
          We believe that a beautiful home starts with a flawless foundation. That is why we handle everything from the initial subfloor preparation to the final sweep up, ensuring every millimeter of your project is executed to the absolute highest standard.
        </p>

        <div class="grid grid-cols-2 md:grid-cols-3 gap-8 py-8 border-y border-white/10" id="stats-container">
          
          <div class="flex flex-col">
            <div class="flex items-baseline text-4xl md:text-5xl font-black text-brand-accent mb-2 drop-shadow-md">
              <span class="stat-counter" data-target="10">0</span>
              <span class="text-3xl md:text-4xl">+</span>
            </div>
            <p class="text-white/60 font-medium uppercase tracking-wide text-sm">Years Experience</p>
          </div>

          <div class="flex flex-col">
            <div class="flex items-baseline text-4xl md:text-5xl font-black text-brand-accent mb-2 drop-shadow-md">
              <span class="stat-counter" data-target="500">0</span>
              <span class="text-3xl md:text-4xl">+</span>
            </div>
            <p class="text-white/60 font-medium uppercase tracking-wide text-sm">Projects Completed</p>
          </div>

          <div class="flex flex-col">
            <div class="flex items-baseline text-4xl md:text-5xl font-black text-brand-accent mb-2 drop-shadow-md">
              <span class="stat-counter" data-target="100">0</span>
              <span class="text-3xl md:text-4xl">%</span>
            </div>
            <p class="text-white/60 font-medium uppercase tracking-wide text-sm">Client Satisfaction</p>
          </div>

        </div>

        <div class="mt-10 flex items-center gap-4">
          <div class="w-12 h-1 bg-brand-accent rounded-full"></div>
          <p class="text-white text-lg font-bold tracking-widest uppercase">Precision Guaranteed</p>
        </div>

      </div>

    </div>
  </div>
</section>

<script>
  // Setup the Intersection Observer to trigger animations on scroll
  const statsContainer = document.getElementById('stats-container');
  const counters = document.querySelectorAll('.stat-counter');
  let animated = false; // Prevent re-animating if they scroll up and down

  const animateCounters = () => {
    counters.forEach(counter => {
      const target = +counter.getAttribute('data-target')!;
      const duration = 2000; // Animation duration in milliseconds (2 seconds)
      let startTimestamp: number | null = null;

      const step = (timestamp: number) => {
        if (!startTimestamp) startTimestamp = timestamp;
        const progress = Math.min((timestamp - startTimestamp) / duration, 1);
        
        // Easing function for smooth slowdown at the end
        const easeOutQuart = 1 - Math.pow(1 - progress, 4);
        
        counter.innerHTML = Math.floor(easeOutQuart * target).toString();
        
        if (progress < 1) {
          window.requestAnimationFrame(step);
        } else {
          counter.innerHTML = target.toString(); // Ensure it ends exactly on the target
        }
      };
      
      window.requestAnimationFrame(step);
    });
  };

  if (statsContainer) {
    const observer = new IntersectionObserver((entries) => {
      if (entries[0].isIntersecting && !animated) {
        animateCounters();
        animated = true; // Flag as animated
        observer.unobserve(statsContainer); // Stop observing once triggered
      }
    }, { threshold: 0.5 }); // Trigger when 50% of the container is visible

    observer.observe(statsContainer);
  }
</script>