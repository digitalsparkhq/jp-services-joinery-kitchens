---
// src/components/VideoShowcase.astro
---

<section class="py-24 bg-stone-50 relative overflow-hidden border-y border-stone-200">
  
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(#000 1px, transparent 1px); background-size: 24px 24px;"></div>

  <div class="max-w-[1600px] mx-auto px-8 lg:px-12 relative z-10">
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 lg:gap-24 items-center">
      
      <div class="relative flex justify-center lg:justify-start order-2 lg:order-1">
        
        <div class="absolute -top-6 -left-6 w-full h-full border-2 border-brand-accent/20 rounded-2xl -z-10 hidden md:block"></div>
        <div class="absolute -bottom-6 -right-6 w-3/4 h-3/4 bg-brand-accent/5 rounded-2xl -z-10 hidden md:block"></div>

        <div class="bg-white p-2 rounded-2xl shadow-[0_20px_50px_rgba(0,0,0,0.08)] border border-stone-100 relative group">
          
          <div class="absolute top-0 left-1/2 -translate-x-1/2 w-1/3 h-1 bg-brand-accent rounded-b-md opacity-0 group-hover:opacity-100 transition-opacity duration-500"></div>

          <div class="rounded-xl overflow-hidden bg-stone-100 relative flex items-center justify-center" style="width: 267px; height: 476px;">
            <iframe 
              src="https://www.facebook.com/plugins/video.php?height=476&href=https%3A%2F%2Fwww.facebook.com%2Freel%2F1739552477027316%2F&show_text=false&width=267&t=0" 
              width="267" 
              height="476" 
              style="border:none;overflow:hidden" 
              scrolling="no" 
              frameborder="0" 
              allowfullscreen="true" 
              allow="autoplay; clipboard-write; encrypted-media; picture-in-picture; web-share">
            </iframe>
          </div>
        </div>
        
        <div class="absolute -bottom-8 md:-right-8 bg-white p-4 rounded-xl shadow-xl border border-stone-100 flex items-center gap-3 animate-fade-up animation-delay-200">
          <div class="w-12 h-12 bg-brand-accent/10 rounded-full flex items-center justify-center text-brand-accent">
             <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path></svg>
          </div>
          <div>
            <p class="text-xs text-stone-500 font-medium uppercase tracking-wider">Commitment to</p>
            <p class="font-bold text-brand-dark">Property Respect</p>
          </div>
        </div>
      </div>

      <div class="max-w-2xl order-1 lg:order-2">
        <div class="inline-flex items-center gap-2 px-4 py-2 rounded-full bg-brand-accent/10 border border-brand-accent/20 text-brand-dark font-bold text-sm tracking-wider mb-6">
          <span class="w-2 h-2 rounded-full bg-brand-accent animate-pulse"></span>
          SEE OUR WORK
        </div>
        
        <h2 class="text-4xl md:text-5xl font-extrabold mb-6 leading-tight text-brand-dark tracking-tight">
          Craftsmanship that <span class="text-brand-accent">speaks for itself.</span>
        </h2>
        
        <p class="text-stone-600 text-lg mb-8 leading-relaxed">
          We don't just lay floors and build custom joinery; we transform your home with precision. From clever space-saving kids' beds to flawless, level flooring runs, every cut is measured to perfection.
        </p>

        <div class="bg-white p-6 md:p-8 rounded-2xl border border-stone-200 shadow-sm mb-8 hover:border-brand-accent/30 transition-colors">
          <div class="flex items-start gap-4">
            <svg class="w-8 h-8 text-brand-accent flex-shrink-0 mt-1" fill="none" stroke="currentColor" viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M15 10l4.553-2.276A1 1 0 0121 8.618v6.764a1 1 0 01-1.447.894L15 14M5 18h8a2 2 0 002-2V8a2 2 0 00-2-2H5a2 2 0 00-2 2v8a2 2 0 002 2z"></path></svg>
            <div>
              <h4 class="font-bold text-brand-dark text-xl">Recent Project Walkthrough</h4>
              <p class="text-stone-600 mt-2 leading-relaxed">
                Take a look at this recent installation featuring premium flooring and bespoke wooden stairs. 
              </p>
              <p class="text-stone-600 mt-3 leading-relaxed border-l-2 border-brand-accent pl-4">
                <span class="text-brand-dark font-semibold">Spot the blue film?</span> We rigorously protect your stairs, carpets, and existing finishes before we even pick up a tool.
              </p>
            </div>
          </div>
        </div>

        <button class="quote-trigger cursor-pointer bg-brand-dark hover:bg-brand-accent text-white hover:text-brand-dark font-bold py-4 px-8 rounded shadow-lg transition-all duration-300 transform hover:-translate-y-1 text-lg flex items-center gap-3 group border-0">
          Discuss Your Project Ideas
          <svg class="w-5 h-5 transform group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
          </svg>
        </button>
      </div>

    </div>
  </div>
</section>